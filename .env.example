# ============================================
# MATCHMIND — Environment Variables
# Copy this file to .env.local and fill in your keys
# ============================================

# Supabase (https://supabase.com — free)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API-Football via RapidAPI (https://rapidapi.com/api-sports/api/api-football)
# Free plan = 100 requests/day — enough to launch
FOOTBALL_API_KEY=your_rapidapi_key

# Stripe (https://stripe.com — free to set up)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXX
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXX

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_ELITE_PRICE_ID=price_xxx
STRIPE_TOKENS_10_PRICE_ID=price_xxx
STRIPE_TOKENS_50_PRICE_ID=price_xxx
STRIPE_TOKENS_200_PRICE_ID=price_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000


